# 通义千问API Key（必须，同时用于LLM和Embedding）
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# Tavily搜索API Key（必须，用于网络检索）
TAVILY_API_KEY=your_tavily_api_key_here

# ChromaDB配置
CHROMA_PERSIST_DIR=./data/vectordb/chroma
CHROMA_COLLECTION_NAME=engineering_qa

# 向量维度（DashScope text-embedding-v2 输出1536维）
EMBEDDING_DIM=1536

# BM25索引存储路径
BM25_INDEX_PATH=./data/vectordb/bm25_index.pkl

# 切片配置
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
TOP_K_RESULTS=5

# API Configuration
API_HOST=0.0.0.0
API_PORT=5002
DEBUG=false
