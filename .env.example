# ===========================================
# 工程质检RAG系统 环境配置模板
# ===========================================
# 复制此文件为 .env 并填入真实的API Key

# LLM Configuration (Qwen/通义千问)
# 获取地址: https://dashscope.console.aliyun.com/
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# Web Search Configuration (Tavily)
# 获取地址: https://tavily.com/
TAVILY_API_KEY=your_tavily_api_key_here

# Milvus Configuration
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_COLLECTION_NAME=engineering_qa
EMBEDDING_DIM=1536

# BM25 Index Path
BM25_INDEX_PATH=./data/vectordb/bm25_index.pkl

# Processing Configuration
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
TOP_K_RESULTS=5

# API Configuration
API_HOST=0.0.0.0
API_PORT=5001
DEBUG=false
